---
interface Props {
  title: string
  number?: number | string
}

const { title, number } = Astro.props
const upper = title.toUpperCase()
const num =
  number !== undefined ? String(number).padStart(2, '0') : null
---

<div class="font-mono mb-3 mt-8" role="heading" aria-level="2">
  <div class="flex items-baseline gap-3 text-sm">
    {num && <span class="text-accent">[{num}]</span>}
    <span class="text-accent font-semibold tracking-widest">{upper}</span>
    <span
      class="flex-1 border-b border-dotted border-foreground/30 -translate-y-[3px]"
      aria-hidden="true"></span>
    <span class="hidden sm:inline text-foreground/45 text-xs uppercase tracking-widest"
      >{Astro.url.host || 'jcalado.com'}</span
    >
  </div>
  <div
    class="mt-1 h-1 border-y border-accent"
    aria-hidden="true"
  ></div>
</div>
