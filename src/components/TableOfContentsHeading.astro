---
import type { MarkdownHeading } from 'astro'

interface Props {
  heading: MarkdownHeading
  isLast: boolean
  parentPipes: boolean[]
}

const {
  heading: { depth, slug, text },
  isLast,
  parentPipes,
} = Astro.props

const indent = parentPipes
  .map((hasPipe) => (hasPipe ? '│  ' : '   '))
  .join('')
const branch = depth === 1 ? '' : isLast ? '└─ ' : '├─ '
---

<li class="flex items-baseline whitespace-pre font-mono text-sm">
  <span class="text-foreground/30 select-none">{indent}{branch}</span>
  <a
    class="line-clamp-1 hover:text-accent text-foreground/85 no-underline"
    href={`#${slug}`}>{text}</a>
</li>

<style>
  li.active-heading a {
    color: var(--theme-accent);
    font-weight: 600;
  }
</style>
