---
import type { MarkdownHeading } from 'astro'

interface Props {
  heading: MarkdownHeading
  isLast: boolean
  parentPipes: boolean[]
}

const {
  heading: { depth, slug, text },
  isLast,
  parentPipes,
} = Astro.props

const indent = parentPipes
  .map((hasPipe) => (hasPipe ? '│  ' : '   '))
  .join('')
const branch = depth === 1 ? '' : isLast ? '└─ ' : '├─ '
---

<li class="flex items-baseline font-mono text-sm min-w-0">
  <span class="text-foreground/30 select-none whitespace-pre shrink-0">{indent}{branch}</span>
  <a
    class="hover:text-accent text-foreground/85 no-underline truncate min-w-0 flex-1"
    title={text}
    href={`#${slug}`}>{text}</a>
</li>

<style>
  li.active-heading a {
    color: var(--theme-accent);
    font-weight: 600;
  }
</style>
