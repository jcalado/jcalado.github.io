---
import type { MarkdownHeading } from 'astro'
import TOCHeading from '~/components/TableOfContentsHeading.astro'

interface Props {
  headings: MarkdownHeading[]
}

const { headings } = Astro.props
const filtered = headings.filter(({ depth }) => depth >= 2 && depth <= 4)

// Compute, for each heading, the list of "pipe slots" needed for indentation.
// At depth d, there are (d - 2) parent slots; each slot is a pipe if there is
// any later heading at exactly that depth before the next heading at <= depth.
const minDepth = 2
type Annotated = { h: MarkdownHeading; isLast: boolean; pipes: boolean[] }
const annotated: Annotated[] = filtered.map((h, i) => {
  const slots = h.depth - minDepth
  const pipes: boolean[] = []
  for (let s = 0; s < slots; s++) {
    const slotDepth = minDepth + s
    let hasLater = false
    for (let j = i + 1; j < filtered.length; j++) {
      const fd = filtered[j].depth
      if (fd <= slotDepth) {
        hasLater = fd === slotDepth
        break
      }
    }
    pipes.push(hasLater)
  }
  let isLast = true
  for (let j = i + 1; j < filtered.length; j++) {
    if (filtered[j].depth < h.depth) break
    if (filtered[j].depth === h.depth) {
      isLast = false
      break
    }
  }
  return { h, isLast, pipes }
})
---

<details
  open
  class="toc relative md:mx-2 xl:mx-0 text-foreground/90 text-sm bg-foreground/3 xl:bg-transparent border border-accent/20 xl:border-none px-4 py-4 mt-5 xl:mt-0 xl:w-full xl:sticky xl:top-10 xl:basis-[300px] 2xl:basis-[340px] xl:order-2 xl:shrink-0 xl:min-w-0 overflow-hidden"
>
  <summary
    class="font-mono text-foreground/60 cursor-pointer list-none marker:hidden marker:content-['']"
  >
    <span class="text-accent">$</span> tree ./toc
  </summary>
  <nav class="w-full mt-3">
    <div class="font-mono text-sm text-foreground/70 mb-1">.</div>
    <ul class="flex flex-col">
      {annotated.map(({ h, isLast, pipes }) => (
        <TOCHeading heading={h} isLast={isLast} parentPipes={pipes} />
      ))}
    </ul>
  </nav>
</details>

<script>
  const anchors = document.querySelectorAll('h2[id], h3[id], h4[id]')
  const links = document.querySelectorAll('details.toc > nav > ul > li')
  if (anchors.length === links.length && anchors.length > 0) {
    window.addEventListener('scroll', () => {
      const scrollTop = window.scrollY
      let highlighted = false
      for (let i = anchors.length - 1; i >= 0; i--) {
        const anchor = anchors[i] as HTMLElement
        if (!highlighted && scrollTop > anchor.offsetTop - 75) {
          links[i].classList.add('active-heading')
          highlighted = true
        } else {
          links[i].classList.remove('active-heading')
        }
      }
    })
  }
</script>
