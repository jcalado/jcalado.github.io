---
import siteConfig from '~/site.config'
import SocialLinks from '~/components/SocialLinks.astro'
const year = new Date().getFullYear()
---

<footer class="font-mono text-xs text-foreground/70 mt-12 pt-6">
  <div class="mb-4 h-1 border-y border-foreground" aria-hidden="true"></div>
  <div class="flex items-baseline gap-3 mb-3 text-accent uppercase tracking-widest">
    <span>[ COLOPHON ]</span>
    <span
      class="flex-1 border-b border-dotted border-foreground/30 -translate-y-[3px]"
      aria-hidden="true"
    ></span>
    <span class="text-foreground/50">EOF</span>
  </div>
  <dl class="grid grid-cols-1 sm:grid-cols-[8rem_1fr] gap-y-1 gap-x-4 leading-6">
    <dt class="text-foreground/45 uppercase tracking-wider">editor</dt>
    <dd>{siteConfig.author} &mdash; CS7BLE / PT</dd>
    <dt class="text-foreground/45 uppercase tracking-wider">imprint</dt>
    <dd>jcalado.com &middot; self-published &middot; {year}</dd>
    <dt class="text-foreground/45 uppercase tracking-wider">typeset</dt>
    <dd>JetBrains Mono &middot; built with <a class="underline hover:text-accent" href="https://astro.build">Astro</a></dd>
    <dt class="text-foreground/45 uppercase tracking-wider">contact</dt>
    <dd class="contact-line">
      {siteConfig.socialLinks && <SocialLinks socialLinks={siteConfig.socialLinks} />}
    </dd>
  </dl>
  <p class="mt-6 text-foreground/40 text-center">
    &mdash; thanks for reading &mdash;
  </p>
</footer>

<style>
  .contact-line :global(ul) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }
</style>
