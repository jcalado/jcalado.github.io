---
import Layout from '~/layouts/Layout.astro'

function lev(a: string, b: string): number {
  const m = a.length, n = b.length
  const dp: number[][] = Array.from({ length: m + 1 }, () => new Array(n + 1).fill(0))
  for (let i = 0; i <= m; i++) dp[i][0] = i
  for (let j = 0; j <= n; j++) dp[0][j] = j
  for (let i = 1; i <= m; i++) {
    for (let j = 1; j <= n; j++) {
      const c = a[i - 1] === b[j - 1] ? 0 : 1
      dp[i][j] = Math.min(dp[i - 1][j] + 1, dp[i][j - 1] + 1, dp[i - 1][j - 1] + c)
    }
  }
  return dp[m][n]
}

const knownTopLevel = ['posts', 'about', 'tags']
const path = Astro.url.pathname
const stripped = path.replace(/^\/+/, '').split('/')[0]

let suggestion: string | undefined
if (stripped) {
  let bestScore = Infinity
  for (const k of knownTopLevel) {
    const d = lev(stripped, k)
    if (d < bestScore) {
      bestScore = d
      suggestion = k
    }
  }
  if (bestScore > 2) suggestion = undefined
}
---

<Layout title="404">
  <pre class="font-mono text-sm whitespace-pre-wrap my-8">
$ cat {path}
bash: {path}: No such file or directory
{suggestion ? `did you mean: /${suggestion}?` : ''}

$ exit 1
</pre>
  {suggestion && <a class="text-link underline" href={`/${suggestion}`}>cd /{suggestion}</a>}
</Layout>
