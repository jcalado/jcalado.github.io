---
import Layout from '~/layouts/Layout.astro'
import { getSortedPosts } from '~/utils'
import PostPreview from '~/components/PostPreview.astro'
import Pagination from '~/components/Pagination.astro'
import SectionHeader from '~/components/SectionHeader.astro'
import siteConfig from '~/site.config'
import TagsSection from '~/components/TagsSection.astro'
import SeriesSection from '~/components/SeriesSection.astro'

const sortedPosts = await getSortedPosts()
const headlinePosts = sortedPosts
  .reverse()
  .slice(0, Math.floor(siteConfig.pageSize / 2))
const postsHaveTags = sortedPosts.some(
  (post) => post.data.tags && post.data.tags.length > 0,
)
const postsHaveSeries = sortedPosts.some((post) => post.data.series)
---

<Layout>
  <aside
    class="font-mono text-xs sm:text-sm my-4 border border-red-500/50 bg-red-500/5 px-3 py-2 flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3"
    aria-label="Support free software"
  >
    <span class="text-red-500 font-semibold tracking-widest uppercase whitespace-nowrap">
      [SUPPORT]
    </span>
    <span class="text-foreground/75 flex-1">
      Enjoying the free software I build? Help keep it going.
    </span>
    <a
      href="https://ko-fi.com/jcalado"
      target="_blank"
      rel="noopener noreferrer"
      class="text-red-500 hover:underline whitespace-nowrap"
    >
      ko-fi.com/jcalado &rarr;
    </a>
  </aside>

  <p class="font-mono text-xs sm:text-sm text-foreground/55 my-4">
    <span class="text-accent">&gt;</span>
    <span class="text-foreground">{sortedPosts.length}</span> entries in the
    archive, {headlinePosts.length} most recent below. Or browse the
    <a href="/posts" class="text-accent hover:underline">archive</a>.
  </p>

  {
    postsHaveSeries && (
      <section>
        <SectionHeader title="Running Series" number="00" />
        <SeriesSection posts={sortedPosts} />
      </section>
    )
  }

  <section>
    <SectionHeader title="Headlines" number="01" />
    {
      headlinePosts.map((post, i) => (
        <PostPreview post={post} index={i} />
      ))
    }
    <div class="mt-4">
      <Pagination nextLink="/posts" nextText="Read the archive" />
    </div>
  </section>

  {
    postsHaveTags && (
      <TagsSection posts={sortedPosts} number="02" />
    )
  }
</Layout>

<style is:global>
  a.heading-anchor {
    display: none !important;
  }
</style>
